# ============================================
# Digital Store Flyer - Environment Variables
# ============================================
# انسخ هذا الملف إلى .env واملأ القيم

# ---- MongoDB (ضروري للتطبيق) ----
# احصل على رابط الاتصال من: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/digital-store?retryWrites=true&w=majority

# ---- Cloudinary (لرفع الصور) ----
# سجل واحصل على البيانات من: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- JWT Authentication ----
# أنشئ سلسلة عشوائية طويلة (64 حرف) باستخدام: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-random-string-here-change-in-production
JWT_EXPIRES_IN=24h

# ---- HMAC (أمان إضافي للـ API) ----
# أنشئ سلسلة عشوائية مختلفة عن JWT_SECRET
HMAC_KEY=another-long-random-string-for-hmac

# ---- LibreTranslate (للترجمة الآلية) ----
# مفتوح المصدر ومجاني بالكامل - يمكنك استخدام الموقع العام أو تشغيله على سيرفرك
# الموقع العام: https://libretranslate.com (محدود بـ 1000 حرف/يوم بدون مفتاح)
# التشغيل الذاتي: docker run -d -p 5000:5000 libretranslate/libretranslate
LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_API_KEY=

# ---- Resend (لإرسال الإيميلات) ----
# سجل واحصل على مفتاح API من: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ---- Seed Key (لإنشاء حساب super_admin أول مرة) ----
# أي كلمة سر تختارها، ترسلها مع الطلب لإنشاء أول مشرف
SEED_KEY=your-secret-seed-key

# ---- Base URL ----
# رابط الموقع بعد النشر (مهم لروابط QR والـ sitemap)
BASE_URL=https://your-domain.vercel.app

# ---- Vite (بيئة الواجهة الأمامية) ----
VITE_APP_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000/api
